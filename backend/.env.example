# MongoDB Atlas connection string
MONGODB_URI=

# Get a free API key from https://gnews.io/  (100 req/day free)
GNEWS_API_KEY=

# Optional second news source — https://marketaux.com  (100 req/day free)
MARKETAUX_API_KEY=

# Email verification — sign up free at https://resend.com → API Keys → Create Key
RESEND_API_KEY=
EMAIL_FROM=SoictStock <onboarding@resend.dev>
FRONTEND_URL=http://localhost:5173

# Set to "true" to wipe ticks + contest state on every boot so prices regenerate
# fresh (keeps redeploys in sync). Leave empty/false to preserve history. Note:
# a fresh regeneration of 1 year of history can take a few minutes on startup.
RESET_ON_BOOT=
